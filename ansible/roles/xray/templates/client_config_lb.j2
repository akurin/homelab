{
  "remarks": "{{ remark }}",
  "log": {
    "loglevel": "debug"
  },
  "dns": {
    "servers": [
      "https://1.1.1.1/dns-query"
    ]
  },
  {# Probes proxy_direct every minute (3-sample average) to determine alive/dead.
     Balancer pool contains only proxy_direct; proxy_cdn is the fallback outbound.
     proxy_direct is always used when alive; proxy_cdn takes over only when all
     proxy_direct probes fail. Strict priority, no latency-based switching. #}
  "burstObservatory": {
    "subjectSelector": ["proxy_direct"],
    "pingConfig": {
      "destination": "https://www.gstatic.com/generate_204",
      "interval": "1m",
      "sampling": 3,
      "timeout": "10s"
    }
  },
  "inbounds": [
    {
      "port": 10808,
      "listen": "127.0.0.1",
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "sniffing": {
        "destOverride": [
          "http",
          "tls",
          "quic"
        ],
        "enabled": true,
        "routeOnly": false
      },
      "tag": "socks_proxy"
    },
    {
      "port": 10807,
      "listen": "127.0.0.1",
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "tag": "socks_direct"
    }
  ],
  "outbounds": [
    {
      "protocol": "vless",
      "tag": "proxy_direct",
      "settings": {
        "vnext": [
          {
            "address": "{{ domain }}",
            "port": 443,
            "users": [
              {
                "id": "{{ user_id }}",
                "email": "{{ user_name }}@{{ inventory_hostname }}",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {{ {
          "path": secret_path,
          "mode": "packet-up"
        } | combine(xray_xhttp_extra_settings | default({})) | to_json }},
        "security": "tls",
        "tlsSettings": {
          "alpn": [
            "h2"
          ]
        }
      }
    },
    {
      "protocol": "vless",
      "tag": "proxy_cdn",
      "settings": {
        "vnext": [
          {
            "address": "{{ server_ip }}",
            "port": 443,
            "users": [
              {
                "id": "{{ user_id }}",
                "email": "{{ user_name }}@{{ inventory_hostname }}",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {{ {
          "path": secret_path,
          "mode": "packet-up"
        } | combine(xray_xhttp_extra_settings | default({})) | to_json }},
        "security": "tls",
        "tlsSettings": {
          "serverName": "{{ cdn_domain }}",
          "alpn": [
            "h2"
          ]
        }
      }
    },
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "balancers": [
      {
        "tag": "balancer",
        "selector": ["proxy_direct"],
        "fallbackTag": "proxy_cdn",
        "strategy": {
          "type": "leastPing"
        }
      }
    ],
    "rules": [
      {
        "type": "field",
        "protocol": ["bittorrent"],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "inboundTag": "socks_direct",
        "outboundTag": "direct"
      }
      {% if routing_profile == 'selective' %}
      {# selective: listed domains/IPs go through the balancer, everything else is direct #}
      {% if proxy_ips %}
      ,{
        "type": "field",
        "ip": {{ proxy_ips | to_json }},
        "balancerTag": "balancer"
      }
      {% endif %}
      {% if proxy_domains %}
      ,{
        "type": "field",
        "domain": {{ proxy_domains | to_json }},
        "balancerTag": "balancer"
      }
      {% endif %}
      ,{
        "type": "field",
        "network": "tcp,udp",
        "outboundTag": "direct"
      }
      {% elif routing_profile == 'proxy_direct' %}
      {# proxy_direct: always use proxy_direct outbound, bypassing the balancer #}
      ,{
        "type": "field",
        "network": "tcp,udp",
        "outboundTag": "proxy_direct"
      }
      {% else %}
      {# full_proxy (default): all traffic goes through the balancer #}
      ,{
        "type": "field",
        "network": "tcp,udp",
        "balancerTag": "balancer"
      }
      {% endif %}
    ]
  }
}
