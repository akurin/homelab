{
  "remarks": "{{ remark }}",
  "log": {
    "loglevel": "debug"
  },
  "dns": {
    "servers": [
      "https://1.1.1.1/dns-query"
    ]
  },
  {% if lb_mode | default(false) %}
  {# LB mode: probes proxy_direct every minute (3-sample average).
     proxy_direct is preferred; proxy_cdn takes over only when all probes fail. #}
  "burstObservatory": {
    "subjectSelector": ["proxy_direct"],
    "pingConfig": {
      "destination": "https://www.gstatic.com/generate_204",
      "interval": "1m",
      "sampling": 3,
      "timeout": "10s"
    }
  },
  {% endif %}
  "inbounds": [
    {
      "port": 10808,
      "listen": "127.0.0.1",
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "sniffing": {
        "destOverride": [
          "http",
          "tls",
          "quic"
        ],
        "enabled": true,
        "routeOnly": true
      },
      "tag": "socks_proxy"
    },
    {
      "port": 10807,
      "listen": "127.0.0.1",
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "tag": "socks_direct"
    }
  ],
  "outbounds": [
    {% if lb_mode | default(false) %}
    {
      "protocol": "vless",
      "tag": "proxy_direct",
      "settings": {
        "vnext": [
          {
            "address": "{{ domain }}",
            "port": 443,
            "users": [
              {
                "id": "{{ user_id }}",
                "email": "{{ user_name }}@{{ inventory_hostname }}",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {{ {
          "path": secret_path,
          "mode": "packet-up"
        } | combine(xray_xhttp_extra_settings | default({})) | to_json }},
        "security": "tls",
        "tlsSettings": {
          "alpn": [
            "h2"
          ]
        }
      }
    },
    {
      "protocol": "vless",
      "tag": "proxy_cdn",
      "settings": {
        "vnext": [
          {
            "address": "{{ server_ip }}",
            "port": 443,
            "users": [
              {
                "id": "{{ user_id }}",
                "email": "{{ user_name }}@{{ inventory_hostname }}",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {{ {
          "path": secret_path,
          "mode": "packet-up"
        } | combine(xray_xhttp_extra_settings | default({})) | to_json }},
        "security": "tls",
        "tlsSettings": {
          "serverName": "{{ cdn_domain }}",
          "alpn": [
            "h2"
          ]
        }
      }
    },
    {% else %}
    {
      "protocol": "vless",
      "tag": "proxy",
      "settings": {
        "vnext": [
          {
            "address": "{{ domain }}",
            "port": 443,
            "users": [
              {
                "id": "{{ user_id }}",
                "email": "{{ user_name }}@{{ inventory_hostname }}",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {{ {
          "path": secret_path,
          "mode": "packet-up"
        } | combine(xray_xhttp_extra_settings | default({})) | to_json }},
        "security": "tls",
        "tlsSettings": {
          "alpn": [
            "h2"
          ]
        }
      }
    },
    {% endif %}
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "balancers": [
      {% if lb_mode | default(false) %}
      {
        "tag": "balancer",
        "selector": ["proxy_direct"],
        "fallbackTag": "proxy_cdn",
        "strategy": {
          "type": "leastPing"
        }
      }
      {% else %}
      {
        "tag": "balancer",
        "selector": ["proxy"]
      }
      {% endif %}
    ],
    "rules": [
      {
        "type": "field",
        "ip": [
          "1.1.1.1"
        ],
        "balancerTag": "balancer"
      },
      {
        "type": "field",
        "protocol": [
          "bittorrent"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "inboundTag": "socks_direct",
        "outboundTag": "direct"
      }
      {% for rule in routing_rules | default([]) %}
      ,{{ rule | to_json }}
      {% endfor %}
    ]
  }
}
