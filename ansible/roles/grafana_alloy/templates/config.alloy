remotecfg {
	url            = "{{GCLOUD_FM_URL}}"
	id             = "{{GCLOUD_FM_COLLECTOR_ID}}"
	poll_frequency = "{{GCLOUD_FM_POLL_FREQUENCY}}"

	basic_auth {
		username = "{{GCLOUD_FM_HOSTED_ID}}"
		password = "{{GCLOUD_RW_API_KEY}}"
	}

	attributes = {
		{% for k, v in (grafana_alloy_collector_attrs | default({}) | dictsort) %}
		{{ k }} = "{{ v }}",
		{% endfor %}
	}
}
